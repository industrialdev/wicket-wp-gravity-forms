{
    "name": "industrialdev/wicket-wp-gravity-forms",
    "description": "Wicket Gravity Forms Plugin",
    "version": "2.3.23",
    "keywords": [
        "wordpress",
        "plugin"
    ],
    "homepage": "https://github.com/industrialdev/wicket-wp-gravity-forms",
    "authors": [
        {
            "name": "Wicket Inc.",
            "homepage": "https://wicket.io"
        }
    ],
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3"
    },
    "scripts": {
        "production": "composer install && composer cs:fix && composer install --no-dev --optimize-autoloader",
        "setup-hooks": "mkdir -p .git/hooks && cp .ci/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push && echo 'Git hooks installed to .git/hooks/pre-push'",
        "cs:lint": "php-cs-fixer fix --dry-run --diff",
        "cs:format": "php-cs-fixer fix",
        "check": [
            "@cs:lint"
        ],
        "cs:fix": "php-cs-fixer fix"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
